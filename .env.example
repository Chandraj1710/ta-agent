# TA Agent - Environment Variables
# Copy to .env and fill in values

# Backend (ta-agent/backend/.env)
PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/ta_agent
GREENHOUSE_API_KEY=your-greenhouse-api-key-here

# LLM (optional, for future agent enhancements)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview
OPENAI_API_KEY=sk-your-key-here

# Frontend (ta-agent/frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_USE_MOCK=true
