PORT=3001
NODE_ENV=development

# LLM Provider Configuration
# Options: 'openai', 'gemini', 'claude', 'groq', 'ollama'
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7

# OpenAI (Paid, High Quality)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Google Gemini (FREE TIER AVAILABLE!)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-key-here

# Anthropic Claude (FREE TIER AVAILABLE!)
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your-claude-key-here

# Groq (FREE & FAST!)
# Get your key from: https://console.groq.com
GROQ_API_KEY=your-groq-key-here

# Ollama (LOCAL & FREE - no API key needed)
# Install from: https://ollama.ai
# Just set LLM_PROVIDER=ollama

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ta_agent

# Greenhouse ATS (Harvest API)
# Create at: Configure >> Dev Center >> API Credential Management
GREENHOUSE_API_KEY=your-greenhouse-api-key-here

# CORS
ALLOWED_ORIGINS=http://localhost:3000
